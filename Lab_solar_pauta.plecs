        Component {
          Type          CScript
          Name          "MPPT3"
          Show          off
          Position      [130, 635]
          Direction     up
          Flipped       off
          LabelPosition south
          Parameter {
            Variable      "DialogGeometry"
            Value         "[2642 356 456 324]"
            Show          off
          }
          Parameter {
            Variable      "NumInputs"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "NumOutputs"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "NumContStates"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "NumDiscStates"
            Value         "5"
            Show          off
          }
          Parameter {
            Variable      "NumZCSignals"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "DirectFeedthrough"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Ts"
            Value         "Ts"
            Show          off
          }
          Parameter {
            Variable      "TerminalBasedSampleTimes"
            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "Parameters"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "LangStandard"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "GnuExtensions"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "HighlightLevel"
            Value         "0"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "#define ST_DUTY   DiscState(0)\n"
"#define ST_PREV_P DiscState(1)\n"
"#define ST_DIR    DiscState(2)\n"
"#define ST_CNT    DiscState(3)\n"
"#define ST_INIT   DiscState(4)\n"
"\n"
"#define P_EPS     0.0\n"
"\n"
"#define DINIT     0.48\n"
"#define DSTEP     0.001\n"
"#define DMIN      0.1\n"
"#define DMAX      0.9\n"
"#define N_PARAM   200\n"
"\n"
"/* Ajusta esto si hay ruido de potencia.\n"
"   Ejemplo: 0.1 para ignorar cambios menores a 0.1 W */\n"
"#define P_EPS     0.0\n"
"\n"
"static double clamp_double(double x, double xmin, double xmax)\n"
"{\n"
"    if (x > xmax) return xmax;\n"
"    if (x < xmin) return xmin;\n"
"    return x;\n"
"}\n"
"\n"
"static int get_N_steps(int N)\n"
"{\n"
"    int n = (int)(N + 0.5);   /* redondea N */\n"
"    if (n < 1) n = 1;\n"
"    return n;\n"
"}"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "if (DMAX <= DMIN)\n"
"{\n"
"    SetErrorMessage(\"MPPT P&O: Dmax debe ser mayor que Dmin\");\n"
"    return;\n"
"}\n"
"\n"
"if (DSTEP <= 0.0)\n"
"{\n"
"    SetErrorMessage(\"MPPT P&O: dD debe ser positivo\");\n"
"    return;\n"
"}\n"
"\n"
"if (N_PARAM < 1.0)\n"
"{\n"
"    SetErrorMessage(\"MPPT P&O: N debe ser >= 1\");\n"
"    return;\n"
"}\n"
"\n"
"/* Inicializacion */\n"
"ST_DUTY   = clamp_double(DINIT, DMIN, DMAX);\n"
"ST_PREV_P = 0.0;\n"
"ST_DIR    = 1.0;     /* direccion inicial de perturbacion */\n"
"ST_CNT    = 0.0;\n"
"ST_INIT   = 0.0;"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "/* La salida se mantiene constante entre actualizac"
"iones */\n"
"OutputSignal(0, 0) = ST_DUTY;"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         "double P;\n"
"double duty;\n"
"double prevP;\n"
"double dir;\n"
"double dP;\n"
"int cnt;\n"
"int Nsteps;\n"
"\n"
"/* Entrada: potencia del panel */\n"
"P = InputSignal(0, 0);\n"
"\n"
"duty   = ST_DUTY;\n"
"prevP  = ST_PREV_P;\n"
"dir    = (ST_DIR >= 0.0) ? 1.0 : -1.0;\n"
"cnt    = (int)ST_CNT;\n"
"Nsteps = get_N_steps(N_PARAM);\n"
"\n"
"/* Este update se llama cada Ts.\n"
"   El P&O real se ejecuta solo cada N pasos. */\n"
"cnt++;\n"
"\n"
"if (cnt >= Nsteps)\n"
"{\n"
"    cnt = 0;\n"
"\n"
"    if (ST_INIT < 0.5)\n"
"    {\n"
"        /* Primera muestra valida: guardo potencia y aplico primera perturbac"
"ion */\n"
"        ST_PREV_P = P;\n"
"        ST_INIT   = 1.0;\n"
"\n"
"        duty = duty + dir * DSTEP;\n"
"    }\n"
"    else\n"
"    {\n"
"        dP = P - prevP;\n"
"\n"
"        /* Perturb and Observe:\n"
"           Si la potencia bajo, invierto direccion.\n"
"           Si subio o quedo igual, mantengo direccion. */\n"
"        if (dP < -P_EPS)\n"
"        {\n"
"            dir = -dir;\n"
"        }\n"
"\n"
"        duty = duty + dir * DSTEP;\n"
"\n"
"        /* Guardo la potencia actual para la proxima comparacion */\n"
"        ST_PREV_P = P;\n"
"    }\n"
"\n"
"    /* Saturacion del duty */\n"
"    if (duty >= DMAX)\n"
"    {\n"
"        duty = DMAX;\n"
"        if (dir > 0.0) dir = -1.0;\n"
"    }\n"
"    else if (duty <= DMIN)\n"
"    {\n"
"        duty = DMIN;\n"
"        if (dir < 0.0) dir = 1.0;\n"
"    }\n"
"\n"
"    ST_DUTY = duty;\n"
"    ST_DIR  = dir;\n"
"}\n"
"\n"
"ST_CNT = (double)cnt;"
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         ""
            Show          off
          }
        }
