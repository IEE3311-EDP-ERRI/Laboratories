"#include <stdio.h>\n"
"#include <math.h>\n"
"\n"
"// CONSTANT DECLARATION\n"
"// Input\n"
"#define Ts  \tParamRealData(0,0)\n"
"//#define Kp  \tParamRealData(1,0)\n"
"//#define Ki  \tParamRealData(2,0)\n"
"\n"
"// Constant\n"
"#define PI    3.14159265\n"
"\n"
"// VARIABLE DECLARATION\n"
"int enable, reset, enable_ff ; \n"
"float error, error_ant , ypi , ypi_ant ;\n"
"float kp, ki, ts  ; \n"
"float ff, sat_pos , sat_neg ;\n"
"\n"
"\n"
"\n"
"\n"
"// DEFINITION STRUCTURES FOR CONTROLLER  \n"
"float PI_array[4] = {0,0,0,0} ;  \n"
" \n"
"\n"
"\n"
"// FUNCTION DECLARATION\n"
"void calculation_pi_array_full(float valores[4], int enable, int reset, int e"
"nable_ff, float kp, float ki, float ts, float ff, float sat_pos, float sat_ne"
"g); \n"
"\n"
"\n"
"\n"
"// FUNCTION DEFINITIONS\n"
"\n"
"\n"
"void calculation_pi_array_full(float valores[4], int enable, int reset, int e"
"nable_ff, float kp, float ki, float ts, float ff, float sat_pos, float sat_ne"
"g)\n"
"{\n"
"\t// y[k] = y[k-1] + e[k]*a1 + e[k-1]*a2 ; \n"
"\t// result[4] = [ y[k] ,  y[k-1]  , e[k]  ,  e[k-1] ]   =  {  0  , 1  ,  2  "
" 3  }\n"
"\t// result[0] = result[1] + (kp+ki*ts/2)*result[2] + (-kp+ki*ts/2)*result[3]"
" ;\n"
"\t\n"
"\t// Reset error acumulado\n"
"   if(reset==1)\n"
"   {\n"
"    \tvalores[3] = 0.0 ; // error anterior \n"
"   }\t\n"
"\t\n"
"\t// Enable FeedForward \n"
"\tif (enable_ff==0){\n"
"    \tff = 0 ; \n"
"   }\t\n"
"   \n"
"\t// Enable calculo PI \n"
"   if(enable==1){\n"
"   \t// Calculo PI = Proporcional + Integral \n"
"   \tvalores[0] = valores[1] + (kp+1*ki*ts/2)*valores[2] + (-kp+1*ki*ts/2)*va"
"lores[3] ;\n"
"   \t\n"
"   \t//Anti-Windup\n"
"\t\tif( (valores[0] + ff) <= sat_pos && (valores[0] + ff) >= sat_neg)\n"
"\t\t{ \n"
"\t\t\tvalores[1] = valores[0] ; // Feed y[k-1] = y[k] ;\t\t\n"
"\t\t\tvalores[0] = valores[0] + ff\t;\t\n"
"\t\t}\n"
"\t\telse // saturado \n"
"\t\t{\n"
"\t\t\t//Saturation salida\n"
"\t\t\tif (valores[0] + ff > sat_pos)\n"
"\t\t\t{\t\n"
"\t\t\t\tvalores[0] = sat_pos  ;  // Positive saturation\n"
"\t\t\t} \n"
"\t\t\telse if (valores[0] + ff < sat_neg)\n"
"\t\t\t{\t\n"
"\t\t\t\tvalores[0] = sat_neg  ;  // Negative saturation\n"
"\t\t\t}\n"
"\t\t\tvalores[1] = valores[0] - ff ; // Feed y[k-1] = y[k] ;\n"
"\t\t}\t \n"
"   }\n"
"   else {\n"
"    \tvalores[0] = 0.0 ; // actuacion actual\n"
